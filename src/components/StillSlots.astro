---
type Props = {
  items: string[];
  locale?: "sv" | "en";
};

const { items, locale = "sv" } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-3">
  {items.map((item, index) => (
    <figure class="aspect-[4/3] border border-line bg-paper p-4">
      <div class="flex h-full flex-col justify-between border border-dashed border-line p-4">
        <span class="eyebrow">{locale === "sv" ? "Bildplats" : "Image slot"} {index + 1}</span>
        <figcaption>
          <p class="font-serif text-2xl">{item}</p>
          <p class="mt-3 text-sm leading-5 text-ink">
            {locale === "sv"
              ? "Ersätts med godkänd produktionsstill från arkiv eller broadcaster."
              : "Replace with approved production still from archive or broadcaster."}
          </p>
        </figcaption>
      </div>
    </figure>
  ))}
</div>
