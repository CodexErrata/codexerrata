---
import type { Locale } from "@/data/site";
import { statsAwardImages, statsAwards, statsAwardsKpis } from "@/data/statsAwards";

type Props = {
  locale?: Locale;
};

const { locale = "sv" } = Astro.props;
const images = statsAwardImages;
const awards = statsAwards;
const kpis = statsAwardsKpis;

const copy = {
  sv: {
    eyebrow: "Om Alaska",
    titlePrefix: "Siffror &",
    titleEmphasis: "utmärkelser",
    awardsLabel: "Priser & nomineringar",
    awardsTitle: "Urval av priser och nomineringar",
    kpiLabel: "Produktionssiffror",
    noteLead: "Alaska Film & TV AB",
    note:
      "Siffror avser perioden 1996-2024. Alla produktionsvolymer inkluderar såväl egna projekt som uppdragsproduktion åt externa beställare."
  },
  en: {
    eyebrow: "About Alaska",
    titlePrefix: "Stats &",
    titleEmphasis: "awards",
    awardsLabel: "Awards & nominations",
    awardsTitle: "Selected awards and nominations",
    kpiLabel: "Production figures",
    noteLead: "Alaska Film & TV AB",
    note:
      "Figures cover the period 1996-2024. Production volume includes both owned projects and commissioned productions for external clients."
  }
} satisfies Record<Locale, Record<string, string>>;
---

<section class="stats-awards-page">
  <header class="stats-page-header">
    <p class="stats-eyebrow">{copy[locale].eyebrow}</p>
    <h1>{copy[locale].titlePrefix} <em>{copy[locale].titleEmphasis}</em></h1>
  </header>

  <div class="stats-split">
    <section class="stats-awards-panel" aria-labelledby="stats-awards-title">
      <p class="stats-panel-label">{copy[locale].awardsLabel}</p>

      <div class="stats-image-grid" aria-label={locale === "sv" ? "Produktioner" : "Productions"}>
        {images.map((image, index) => (
          <figure class:list={["stats-image-cell", { "is-tall": index === 0 }]}>
            <img src={image.src} alt={image.alt[locale]} loading={index === 0 ? "eager" : "lazy"} decoding="async" />
            <figcaption>{image.label[locale]}</figcaption>
          </figure>
        ))}
      </div>

      <h2 id="stats-awards-title" class="stats-section-title">{copy[locale].awardsTitle}</h2>
      <div class="stats-awards-list">
        {awards.map((award) => (
          <article class="stats-award-row">
            <span class="stats-award-year">{award.year}</span>
            <div class="stats-award-body">
              <h3>{award.award}</h3>
              <p>{award.show[locale]}</p>
              <span class:list={["stats-award-status", { "is-won": award.statusKind === "won" }]}>
                {award.status[locale]}
              </span>
            </div>
            <p class="stats-award-category">{award.category[locale]}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="stats-kpi-panel" aria-labelledby="stats-kpi-title">
      <p id="stats-kpi-title" class="stats-panel-label">{copy[locale].kpiLabel}</p>

      <div class="stats-kpi-grid">
        {kpis.map((kpi) => (
          <article class:list={["stats-kpi-cell", { "is-featured": kpi.featured }]}>
            <p class="stats-kpi-label">{kpi.label[locale]}</p>
            <div class="stats-kpi-number-wrap">
              <span class="stats-kpi-counter" data-target={kpi.target} data-suffix={kpi.suffix?.[locale] ?? ""}>0</span>
            </div>
            <p class="stats-kpi-sublabel">{kpi.sublabel[locale]}</p>
          </article>
        ))}
      </div>

      <p class="stats-kpi-note">
        <strong>{copy[locale].noteLead}</strong> - {copy[locale].note}
      </p>
    </section>
  </div>
</section>

<script is:inline>
  function formatStatsCounter(value) {
    return value.toLocaleString("sv-SE");
  }

  function easeOutExpo(t) {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function setCounterValue(el, value) {
    const suffix = el.dataset.suffix || "";
    el.textContent = `${formatStatsCounter(value)}${suffix}`;
  }

  function animateStatsCounter(el) {
    const target = Number.parseInt(el.dataset.target || "0", 10);
    const duration = target > 500 ? 3200 : target > 100 ? 2600 : 2100;
    const startTime = performance.now();

    function tick(now) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round(easeOutExpo(progress) * target);

      setCounterValue(el, current);

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        setCounterValue(el, target);
      }
    }

    requestAnimationFrame(tick);
  }

  const statsCounters = document.querySelectorAll(".stats-awards-page .stats-kpi-counter[data-target]");
  const shouldReduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!("IntersectionObserver" in window) || shouldReduceMotion) {
    statsCounters.forEach((counter) => {
      setCounterValue(counter, Number.parseInt(counter.dataset.target || "0", 10));
    });
  } else {
    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        animateStatsCounter(entry.target);
        statsObserver.unobserve(entry.target);
      });
    }, { threshold: 0.3 });

    statsCounters.forEach((counter) => statsObserver.observe(counter));
  }
</script>

<style>
  .stats-awards-page {
    --stats-paper: #f5f0e8;
    --stats-ink: #1a1a18;
    --stats-ink-mid: #4a4a44;
    --stats-ink-dim: #8a8a80;
    --stats-rule: #c8b89a;
    --stats-rule-light: #ddd6c8;
    --stats-accent: #6b4f3a;

    background: var(--stats-paper);
    color: var(--stats-ink);
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .stats-page-header {
    border-bottom: 1px solid var(--stats-rule);
    padding: clamp(3rem, 4vw + 1rem, 4rem) clamp(1rem, 4vw, 3.25rem) clamp(2.25rem, 4vw, 3rem);
  }

  .stats-eyebrow,
  .stats-panel-label,
  .stats-section-title,
  .stats-kpi-label {
    color: var(--stats-ink-dim);
    font-size: 11px;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .stats-eyebrow {
    margin: 0 0 18px;
  }

  .stats-page-header h1 {
    font-family: "EB Garamond", Georgia, Cambria, "Times New Roman", serif;
    font-size: clamp(42px, 5vw, 72px);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.08;
    margin: 0;
    max-width: 640px;
  }

  .stats-page-header h1 em {
    font-style: italic;
    font-weight: 400;
  }

  .stats-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: clamp(32rem, 70vh, calc(100vh - 160px));
  }

  .stats-awards-panel,
  .stats-kpi-panel {
    padding: clamp(2rem, 4vw + 1rem, 3.5rem) clamp(1rem, 4vw, 3.25rem) clamp(2.5rem, 5vw, 4.5rem);
  }

  .stats-awards-panel {
    border-right: 1px solid var(--stats-rule);
  }

  .stats-kpi-panel {
    display: flex;
    flex-direction: column;
  }

  .stats-panel-label {
    margin: 0 0 32px;
  }

  .stats-image-grid {
    display: grid;
    gap: 2px;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    margin-bottom: 48px;
  }

  .stats-image-cell {
    aspect-ratio: 4 / 3;
    background:
      repeating-linear-gradient(
        -45deg,
        var(--stats-rule-light) 0,
        var(--stats-rule-light) 1px,
        var(--stats-paper) 1px,
        var(--stats-paper) 9px
      );
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .stats-image-cell.is-tall {
    aspect-ratio: auto;
    grid-row: span 2;
  }

  .stats-image-cell img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .stats-image-cell figcaption {
    align-items: flex-end;
    background: linear-gradient(to bottom, rgba(26, 26, 24, 0) 40%, rgba(26, 26, 24, 0.55) 100%);
    bottom: 0;
    color: rgba(245, 240, 232, 0.78);
    display: flex;
    font-family: "DM Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.75rem;
    inset-inline: 0;
    letter-spacing: 0.06em;
    min-height: 42%;
    padding: 10px 12px;
    position: absolute;
    text-transform: uppercase;
  }

  .stats-section-title {
    border-bottom: 1px solid var(--stats-rule);
    margin: 0;
    padding-bottom: 10px;
  }

  .stats-awards-list {
    display: grid;
  }

  .stats-award-row {
    align-items: baseline;
    border-bottom: 1px solid var(--stats-rule-light);
    display: grid;
    gap: 16px;
    grid-template-columns: auto minmax(0, 1fr) auto;
    margin: 0;
    padding: 16px 0;
  }

  .stats-award-row:last-child {
    border-bottom: 0;
  }

  .stats-award-year {
    color: var(--stats-ink-dim);
    font-family: "DM Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .stats-award-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stats-award-body h3 {
    font-family: "EB Garamond", Georgia, Cambria, "Times New Roman", serif;
    font-size: 17px;
    font-weight: 500;
    line-height: 1.25;
    margin: 0;
  }

  .stats-award-body p {
    color: var(--stats-ink-mid);
    font-size: 0.88rem;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .stats-award-status {
    align-self: flex-start;
    border: 1px solid var(--stats-rule);
    color: var(--stats-ink-dim);
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    margin-top: 4px;
    padding: 2px 7px;
    text-transform: uppercase;
  }

  .stats-award-status.is-won {
    border-color: var(--stats-accent);
    color: var(--stats-accent);
  }

  .stats-award-category {
    color: var(--stats-ink-dim);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin: 0;
    max-width: 120px;
    text-align: right;
    text-transform: uppercase;
  }

  .stats-kpi-grid {
    border-left: 1px solid var(--stats-rule);
    border-top: 1px solid var(--stats-rule);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    margin-top: 32px;
  }

  .stats-kpi-cell {
    border-bottom: 1px solid var(--stats-rule);
    border-right: 1px solid var(--stats-rule);
    overflow: hidden;
    padding: 36px 32px 32px;
    position: relative;
  }

  .stats-kpi-cell.is-featured {
    grid-column: span 2;
    padding: 48px 40px 40px;
  }

  .stats-kpi-label {
    margin: 0 0 16px;
  }

  .stats-kpi-cell.is-featured .stats-kpi-label {
    font-size: 12px;
  }

  .stats-kpi-number-wrap {
    align-items: baseline;
    display: flex;
    gap: 4px;
    margin-bottom: 10px;
  }

  .stats-kpi-counter {
    color: var(--stats-ink);
    font-family: "DM Mono", "SFMono-Regular", Consolas, monospace;
    font-size: clamp(42px, 4.5vw, 64px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
  }

  .stats-kpi-cell.is-featured .stats-kpi-counter {
    font-size: clamp(72px, 8vw, 108px);
  }

  .stats-kpi-sublabel {
    color: var(--stats-ink-mid);
    font-size: 12px;
    line-height: 1.45;
    margin: 0;
    max-width: 180px;
  }

  .stats-kpi-note {
    border-top: 1px solid var(--stats-rule-light);
    color: var(--stats-ink-dim);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: auto 0 0;
    max-width: 360px;
    padding-top: 48px;
  }

  .stats-kpi-note strong {
    color: var(--stats-ink-mid);
    font-weight: 700;
  }

  @media (max-width: 1023px) {
    .stats-split {
      grid-template-columns: 1fr;
    }

    .stats-awards-panel {
      border-bottom: 1px solid var(--stats-rule);
      border-right: 0;
    }

    .stats-kpi-note {
      margin-top: 48px;
    }
  }

  @media (max-width: 767px) {
    .stats-page-header h1 {
      font-size: clamp(2.6rem, 12vw, 3.5rem);
    }

    .stats-split {
      min-height: 0;
    }

    .stats-image-grid,
    .stats-kpi-grid {
      grid-template-columns: 1fr;
    }

    .stats-image-cell.is-tall {
      aspect-ratio: 4 / 3;
      grid-row: auto;
    }

    .stats-award-row {
      align-items: start;
      grid-template-columns: auto minmax(0, 1fr);
    }

    .stats-award-category {
      grid-column: 2;
      max-width: none;
      text-align: left;
    }

    .stats-kpi-cell,
    .stats-kpi-cell.is-featured {
      grid-column: auto;
      padding: 30px 24px 28px;
    }

    .stats-kpi-cell.is-featured .stats-kpi-counter {
      font-size: clamp(64px, 20vw, 92px);
    }
  }
</style>
