---
import ContactGrid from "@/components/ContactGrid.astro";
import PageHero from "@/components/PageHero.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { site } from "@/data/site";
---

<SiteLayout
  title="Kontakt"
  description="Direkta kontaktvägar till Alaska Film & TV för beställare, uppdrag, press och produktion."
  path="/kontakt"
  alternatePath="/en/contact"
>
  <PageHero title="Kontakta oss" />

  <section class="container py-16">
    <div class="mb-8 border-b border-ink pb-6">
      <p class="eyebrow">E-post</p>
      <a class="mt-3 block font-serif text-4xl underline" href={`mailto:${site.email}`}>{site.email}</a>
      <p class="eyebrow mt-10">Jobbansökningar</p>
      <a class="mt-3 block font-serif text-4xl underline" href={`mailto:${site.jobApplicationsEmail}`}>{site.jobApplicationsEmail}</a>
      <p class="mt-4 text-ink">Skicka CV, portfolio och spontanansökningar till denna adress.</p>
      <p class="mt-4 text-ink">{site.address}</p>
    </div>
    <ContactGrid />
  </section>
</SiteLayout>
