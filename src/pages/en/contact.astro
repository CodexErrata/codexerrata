---
import ContactGrid from "@/components/ContactGrid.astro";
import PageHero from "@/components/PageHero.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { site } from "@/data/site";
---

<SiteLayout
  title="Contact"
  description="Direct contact routes to Alaska Film & TV for commissioners, commissioned work, press and production."
  locale="en"
  path="/en/contact"
  alternatePath="/kontakt"
>
  <PageHero title="Contact us" />

  <section class="container py-16">
    <div class="mb-8 border-b border-ink pb-6">
      <p class="eyebrow">Email</p>
      <a class="mt-3 block font-serif text-4xl underline" href={`mailto:${site.email}`}>{site.email}</a>
      <p class="eyebrow mt-10">Job applications</p>
      <a class="mt-3 block font-serif text-4xl underline" href={`mailto:${site.jobApplicationsEmail}`}>{site.jobApplicationsEmail}</a>
      <p class="mt-4 text-ink">Send CVs, portfolios and applications to this address.</p>
      <p class="mt-4 text-ink">{site.address}</p>
    </div>
    <ContactGrid locale="en" />
  </section>
</SiteLayout>
