---
import PageHero from "@/components/PageHero.astro";
import ProductionCard from "@/components/ProductionCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getProductionsByBucket } from "@/data/site";

const groupedProductions = getProductionsByBucket();
---

<SiteLayout
  title="Productions"
  description="Search and filter Alaska Film & TV productions by title, genre and year."
  locale="en"
  path="/en/productions"
  alternatePath="/produktioner"
>
  <PageHero
    eyebrow="Archive"
    title="Productions with metadata visible from the start."
    intro="The archive is built for commissioners, press and industry users. Years, genre and season information are designed to be clear and easy to complete as the production archive is finalised."
  />

  <section class="container py-12" data-archive>
    {groupedProductions.map((bucket, index) => (
      <div class={index === 0 ? "" : "mt-14"} data-production-group data-category={bucket.id}>
        <div class="border-b border-ink pb-5" data-group-heading>
          <p class="eyebrow">{bucket.eyebrow.en}</p>
          <h2 class="mt-3 font-serif text-5xl">{bucket.label.en}</h2>
        </div>
        {bucket.items.map((production) => <ProductionCard production={production} locale="en" />)}
      </div>
    ))}

    <p class="hidden border-t border-line py-10 text-lg" data-empty>No productions match the current filters.</p>
  </section>

  <script>
    const searchInputs = Array.from(document.querySelectorAll<HTMLInputElement>("[data-filter-search]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".production-card"));
    const groups = Array.from(document.querySelectorAll<HTMLElement>("[data-production-group]"));
    const empty = document.querySelector<HTMLElement>("[data-empty]");
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q") ?? "";
    const category = params.get("category") ?? "";
    const validCategories = new Set(["factual", "true-crime", "podcasts"]);
    const activeCategory = validCategories.has(category) ? category : "";
    let activeQuery = initialQuery;

    searchInputs.forEach((input) => {
      input.value = initialQuery;
    });

    function applyFilters() {
      const query = activeQuery.trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const matchesSearch = !query || card.textContent?.toLowerCase().includes(query);
        const matchesCategory = !activeCategory || card.dataset.category === activeCategory;
        const shouldShow = Boolean(matchesSearch && matchesCategory);
        card.hidden = !shouldShow;
        if (shouldShow) visible += 1;
      });

      groups.forEach((group) => {
        const groupCards = Array.from(group.querySelectorAll<HTMLElement>(".production-card"));
        const groupHasVisibleCards = groupCards.some((card) => !card.hidden);
        group.hidden = !groupHasVisibleCards;
      });

      if (empty) empty.hidden = visible !== 0;
      empty?.classList.toggle("hidden", visible !== 0);
    }

    searchInputs.forEach((input) => input.addEventListener("input", () => {
      activeQuery = input.value;
      searchInputs.forEach((otherInput) => {
        if (otherInput !== input) otherInput.value = input.value;
      });
      applyFilters();
    }));
    applyFilters();
  </script>
</SiteLayout>
