---
import PageHero from "@/components/PageHero.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import StatsAwardsPage from "@/components/StatsAwardsPage.astro";
import TeamGrid from "@/components/TeamGrid.astro";
---

<SiteLayout
  title="Company"
  description="About Alaska Film & TV's position, history, working method and Efterlyst legacy."
  locale="en"
  path="/en/company"
  alternatePath="/bolaget"
>
  <PageHero
    eyebrow="Company"
    title="A production company built for editorial presence and difficult environments."
    intro="Alaska Film & TV is based in Stockholm and works across factual entertainment, documentary, true crime, social journalism, reality and commissioned production."
  />

  <section id="team" class="container scroll-mt-28 py-16">
    <div class="mb-10 grid gap-8 border-t border-ink pt-6 md:grid-cols-[0.7fr_1.3fr]">
      <div>
        <p class="eyebrow">Team</p>
        <h2 class="mt-4 font-serif text-5xl leading-tight">The people behind the production.</h2>
      </div>
    </div>
    <TeamGrid locale="en" />
  </section>

  <section id="stats-awards" class="scroll-mt-28">
    <StatsAwardsPage locale="en" />
  </section>
</SiteLayout>
