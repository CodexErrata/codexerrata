---
import HomeStatsAwardsTeaser from "@/components/HomeStatsAwardsTeaser.astro";
import PageHero from "@/components/PageHero.astro";
import ProductionCard from "@/components/ProductionCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { productionBucketId, productions } from "@/data/site";

const initialProductionCount = 3;
const productionBatchSize = 8;
const featuredProductionSlugs = ["efterlyst", "gruvan", "gransbevakarna-sverige"];
const featuredProductions = featuredProductionSlugs.flatMap((slug) => {
  const production = productions.find((candidate) => candidate.slug === slug);
  return production ? [production] : [];
});
const orderedProductions = [
  ...featuredProductions,
  ...productions.filter((production) => productionBucketId(production) !== "podcasts"),
  ...productions.filter((production) => productionBucketId(production) === "podcasts")
].filter((production, index, allProductions) => allProductions.findIndex((candidate) => candidate.slug === production.slug) === index);
---

<SiteLayout
  title="Production in demanding environments"
  description="Alaska Film & TV produces factual entertainment, documentary, true crime and commissioned editorial work for broadcasters, companies and public bodies."
  locale="en"
  path="/en"
  alternatePath="/"
>
  <PageHero
    title="Stories that demand trust before they demand a camera"
    intro="Alaska Film & TV creates factual series, documentaries, true crime, reality and editorial commissioned work. The strength is in environments where authorities, workplaces, broadcaster requirements and participant trust need to hold together."
  />

  <section class="container py-16" data-home-productions>
    <div class="mb-8 flex flex-col justify-between gap-4 pb-6 md:flex-row md:items-end">
      <div>
        <h2 class="font-serif text-5xl"><a class="no-underline transition-opacity hover:opacity-70" href="/en/productions">Productions</a></h2>
      </div>
    </div>
    <div data-production-list>
      {orderedProductions.map((production, index) => (
        <ProductionCard production={production} locale="en" hidden={index >= initialProductionCount} />
      ))}
    </div>
    {
      orderedProductions.length > initialProductionCount && (
        <div class="mt-8 flex justify-center">
          <button
            class="border border-ink px-5 py-3 font-semibold"
            type="button"
            data-production-action
            data-initial-count={initialProductionCount}
            data-batch-size={productionBatchSize}
            data-label-more="More productions"
            data-label-hide="Hide productions"
            aria-expanded="false"
          >
            More productions
          </button>
        </div>
      )
    }
  </section>

  <HomeStatsAwardsTeaser locale="en" />

  <script>
    const productionSection = document.querySelector<HTMLElement>("[data-home-productions]");
    const productionList = document.querySelector<HTMLElement>("[data-production-list]");
    const actionButton = document.querySelector<HTMLButtonElement>("[data-production-action]");
    const productionCards = Array.from(productionList?.querySelectorAll<HTMLElement>(".production-card") ?? []);
    const initialCount = Number(actionButton?.dataset.initialCount ?? 5);
    const batchSize = Number(actionButton?.dataset.batchSize ?? 8);
    let visibleCount = productionCards.filter((card) => !card.hidden).length;

    function updateProductionControls() {
      const isExpanded = visibleCount > initialCount;
      const allVisible = visibleCount >= productionCards.length;

      if (!actionButton) return;
      actionButton.hidden = productionCards.length <= initialCount;
      actionButton.textContent = allVisible
        ? actionButton.dataset.labelHide ?? "Hide productions"
        : actionButton.dataset.labelMore ?? "More productions";
      actionButton.setAttribute("aria-expanded", String(isExpanded));
    }

    function hideExtraProductions({ scrollToTop = false } = {}) {
      productionCards.slice(initialCount).forEach((card) => {
        card.hidden = true;
      });
      visibleCount = Math.min(initialCount, productionCards.length);
      updateProductionControls();
      if (scrollToTop) productionSection?.scrollIntoView({ block: "start" });
    }

    actionButton?.addEventListener("click", () => {
      if (visibleCount >= productionCards.length) {
        hideExtraProductions({ scrollToTop: true });
        return;
      }

      const nextVisibleCount = Math.min(visibleCount + batchSize, productionCards.length);
      productionCards.slice(visibleCount, nextVisibleCount).forEach((card) => {
        card.hidden = false;
      });
      visibleCount = nextVisibleCount;
      updateProductionControls();
    });

    updateProductionControls();
  </script>
</SiteLayout>
