---
import PageHero from "@/components/PageHero.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import StatsAwardsPage from "@/components/StatsAwardsPage.astro";
import TeamGrid from "@/components/TeamGrid.astro";
---

<SiteLayout
  title="Bolaget"
  description="Om Alaska Film & TV:s position, historik, arbetssätt och Efterlyst-arv."
  path="/bolaget"
  alternatePath="/en/company"
>
  <PageHero
    eyebrow="Bolaget"
    title="Ett produktionsbolag byggt för redaktionell närvaro och svåra miljöer."
    intro="Alaska Film & TV är baserat i Stockholm och verkar inom faktabaserad underhållning, dokumentär, true crime, social journalistik, reality och uppdragsproduktion."
  />

  <section class="bg-ink py-16 text-white">
    <div class="container grid gap-10 md:grid-cols-[1fr_1fr]">
      <h2 class="font-serif text-5xl leading-tight">Inte störst i ord. Starkast där produktionen måste fungera.</h2>
      <p class="text-xl leading-8 text-white">Den strategiska riktningen är att ersätta generiska publikpåståenden med konkret kompetens: tillträde, logistik, safety, juridik, myndighetskontakt, redaktionell hållning och leverans till broadcaster.</p>
    </div>
  </section>

  <section id="team" class="container scroll-mt-28 py-16">
    <div class="mb-10 grid gap-8 border-t border-ink pt-6 md:grid-cols-[0.7fr_1.3fr]">
      <div>
        <p class="eyebrow">Team</p>
        <h2 class="mt-4 font-serif text-5xl leading-tight">Människorna bakom produktionen.</h2>
      </div>
    </div>
    <TeamGrid />
  </section>

  <section id="siffror-utmarkelser" class="scroll-mt-28">
    <StatsAwardsPage />
  </section>
</SiteLayout>
