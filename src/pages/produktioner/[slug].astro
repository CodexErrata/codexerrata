---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { productionPath, productions } from "@/data/site";

export function getStaticPaths() {
  return productions.map((production) => ({
    params: { slug: production.slug },
    props: { production }
  }));
}

const { production } = Astro.props;
const tvSeriesSchema = {
  "@context": "https://schema.org",
  "@type": "TVSeries",
  name: production.title,
  description: production.description.sv,
  genre: production.genres,
  productionCompany: "Alaska Film & TV"
};
const descriptionGridClass = production.artwork ? "md:grid-cols-[0.7fr_1.3fr]" : "md:grid-cols-1";
---

<SiteLayout
  title={production.title}
  description={production.summary.sv}
  path={productionPath(production, "sv")}
  alternatePath={productionPath(production, "en")}
  structuredData={tvSeriesSchema}
>
  <article>
    <header class="archive-rule bg-bone">
      <div class="container py-16 md:py-24">
        <div>
          <p class="eyebrow">{production.channel}</p>
          <h1 class="mt-5 font-serif text-[clamp(3rem,15vw,5.25rem)] leading-[0.95] md:text-8xl">{production.title}</h1>
        </div>
      </div>
    </header>

    <section class:list={["container grid gap-10 py-14", descriptionGridClass]}>
      <div class="measure text-xl leading-9 text-ink">
        <p>{production.description.sv}</p>
      </div>
      {
        production.artwork && (
          <img
            class="aspect-video w-full self-start border border-ink object-cover"
            src={production.artwork.src}
            width={production.artwork.width}
            height={production.artwork.height}
            alt={production.artwork.alt.sv}
            loading="lazy"
            decoding="async"
          />
        )
      }
    </section>

    <section class="container py-10">
      <div class="border-y border-line py-8">
        <p class="eyebrow">Trailer / klipp</p>
        {production.trailerUrl ? (
          <a class="mt-4 inline-block text-lg font-semibold underline" href={production.trailerUrl}>Öppna klipp</a>
        ) : (
          <p class="mt-4 text-lg text-ink">Ingen godkänd trailer eller klipplänk tillagd ännu. Videor ska bäddas in utan autoplay.</p>
        )}
      </div>
    </section>
  </article>
</SiteLayout>
