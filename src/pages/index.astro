---
import ProductionGrid from "@/components/ProductionGrid.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { podcastProductions, showProductions } from "@/data/site";
---

<SiteLayout
  description="Alaska Film & TV is a Stockholm-based production company for factual television, documentary, reality, true crime and audio."
>
  <section class="section-block section-block--archive-grid" aria-labelledby="home-productions-title">
    <h1 id="home-productions-title" class="visually-hidden">Alaska Film & TV productions</h1>
    <ProductionGrid productions={showProductions} labelledBy="home-productions-title" variant="mosaic" />
  </section>

  <section class="section-block podcast-section" aria-labelledby="home-podcast-productions-title">
    <div class="section-heading">
      <h2 id="home-podcast-productions-title">Podcasts</h2>
    </div>
    <ProductionGrid productions={podcastProductions} labelledBy="home-podcast-productions-title" variant="podcast" />
  </section>
</SiteLayout>
